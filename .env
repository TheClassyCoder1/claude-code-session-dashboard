# Defaults — override privately in .env.local (gitignored).

# Extra origins allowed to reach the Next dev server (comma-separated, no scheme).
# Needed when opening the dashboard through a tunnel (e.g. ngrok) from a phone —
# without it, dev-mode assets are blocked cross-origin and the UI renders but
# nothing is clickable. Example:
# DEV_ORIGINS=your-tunnel.ngrok-free.app
DEV_ORIGINS=
# Optional: gate action APIs behind a token (see README)
# DASHBOARD_TOKEN=change-me
